# Copy to .env and fill in. docker-compose loads this file into the backend service.

# --- Required: Google AI Studio / Gemini ---
# Use either GOOGLE_API_KEY or GEMINI_API_KEY (the backend accepts both).
GOOGLE_API_KEY=your_key_here
# GEMINI_API_KEY=your_key_here

# --- Optional: backend tuning ---
# Comma-separated browser origins allowed to call the API (FastAPI CORS).
# The frontend container talks to the backend over the internal docker network,
# so browsers only need the host-exposed origin (default: http://localhost:8080).
# CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080,http://localhost:5173

# Gemini model + cost overrides (defaults are fine for gemini-2.0-flash)
# GEMINI_MODEL_ID=gemini-3-flash-preview
# GEMINI_COST_INPUT_PER_1K=0.0001
# GEMINI_COST_OUTPUT_PER_1K=0.0002

# --- Required: ML urgent-keyword feature count (comma-separated; no commas inside a phrase) ---
URGENT_PATTERNS=refund,cancel,broken,not working,stolen,charged,delivery,wait,Worst,money,asap,now,today,tommorow,very,urgent,missing,quickly,unacceptable,dissapointed,never arrived,scam,illegal,waiting,tonight,stole,attorney,late,wrong,stuck,fucking,shit
